APP_PORT=8080

POSTGRES_DB=myeasybudget
POSTGRES_USER=myeasybudget_user
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_PORT=5433

# Must be at least 32 bytes and must not be the in-code default. Override in production.
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=PT1H

# Comma-separated list of allowed browser origins for the frontend.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Outbound email (SMTP) used to send verification links.
SPRING_MAIL_USERNAME=your_smtp_username_here
SPRING_MAIL_PASSWORD=your_smtp_app_password_here
APP_MAIL_FROM=no-reply@my-easy-budget.com

# Base URL the verification link points at (the frontend's origin).
APP_FRONTEND_BASE_URL=http://localhost:5173
# Lifetime of an email-verification token (ISO-8601 duration).
EMAIL_VERIFICATION_TOKEN_EXPIRATION=PT24H
# DEV ONLY: log the verification link instead of relying on real email delivery.
# Never enable in production (it writes a secret token to the logs).
APP_MAIL_LOG_VERIFICATION_LINK=false
